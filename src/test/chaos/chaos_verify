#!/usr/bin/env python3
#
# Chaos - KISS version + verify
#

import argparse
import glob
import os
import random
import re
import shlex
import socket
import subprocess
import sys
import time


DEFAULT_TIMEOUT = 5.0
BHIST_TIMEOUT = 5.0
ARCHIVE_GRACE = 60.0
ARCHIVE_POLL = 0.25

PROC_NAMES = {
    "lim": "lim",
    "mbd": "mbd",
    "sbd": "sbd",
}


def ts():
    return time.strftime("%Y-%m-%d %H:%M:%S")


def log(msg):
    sys.stdout.write(f"{ts()} {msg}\n")
    sys.stdout.flush()


def elog(msg):
    sys.stderr.write(f"{ts()} {msg}\n")
    sys.stderr.flush()


def run(cmd, timeout=DEFAULT_TIMEOUT):
    try:
        return subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired as e:
        out = e.stdout if e.stdout is not None else ""
        err = e.stderr if e.stderr is not None else ""
        return subprocess.CompletedProcess(cmd, 124, out, err)


def extract_jobid(txt):
    m = re.search(r"Job\s+<(\d+)>", txt)
    if not m:
        return None
    try:
        return int(m.group(1))
    except Exception:
        return None


def submit_one(queue, cmd_str):
    cmd = ["bsub", "-o", "/dev/null", "-e", "/dev/null"]
    if queue:
        cmd += ["-q", queue]

    try:
        cmd += shlex.split(cmd_str)
    except ValueError as e:
        elog(f"chaos: bad command string: {cmd_str!r}: {e}")
        return None

    cp = run(cmd)

    if cp.returncode == 124:
        if cp.stderr:
            for line in cp.stderr.splitlines():
                elog(line)
        else:
            elog(f"chaos: timeout: {' '.join(cmd)}")
        return None

    if cp.returncode != 0:
        if cp.stderr:
            for line in cp.stderr.splitlines():
                elog(line)
        else:
            elog(f"chaos: command failed rc={cp.returncode}: {' '.join(cmd)}")
        return None

    return extract_jobid(cp.stdout)


def read_hosts_file(path):
    hosts = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            hosts.append(line)
    return hosts


def is_up(host, kind):
    proc = PROC_NAMES.get(kind)
    if not proc:
        return False

    if host == socket.gethostname():
        cp = run(["pgrep", "-x", proc])
        return cp.returncode == 0

    cp = run(["ssh", host, "pgrep", "-x", proc])
    return cp.returncode == 0


def kill_one(host, kind):
    proc = PROC_NAMES.get(kind)
    if not proc:
        return False

    if host == socket.gethostname():
        cp = run(["pkill", "-KILL", "-x", proc])
        return cp.returncode == 0

    cp = run(["ssh", host, "pkill", "-KILL", "-x", proc])
    return cp.returncode == 0


def bhist_status(jobid, timeout):
    cp = run(["bhist", str(jobid)], timeout=timeout)

    if cp.returncode == 124:
        return ("TIMEOUT", cp.stdout, cp.stderr)

    if cp.returncode != 0:
        return ("ERROR", cp.stdout, cp.stderr)

    # Example: "Job <308>, ... Status <DONE> ..."
    m = re.search(r"Status\s+<([^>]+)>", cp.stdout)
    if not m:
        return ("UNKNOWN", cp.stdout, cp.stderr)

    return (m.group(1).strip().upper(), cp.stdout, cp.stderr)


def is_finished_status(st):
    # KISS: treat DONE/EXIT as finished.
    return st in ("DONE", "EXIT")


def state_paths(workdir):
    return (
        os.path.join(workdir, "state"),
        os.path.join(workdir, ".archive"),
        os.path.join(workdir, "jobs"),
    )


def check_workdir_layout(workdir):
    st_dir, ar_dir, jobs_dir = state_paths(workdir)
    for d in (st_dir, ar_dir, jobs_dir):
        if not os.path.isdir(d):
            raise SystemExit(f"chaos: verify: missing dir: {d}")
    return True


def archive_has_job(ar_dir, jobid):
    # real naming: <unixtime>.<jobid> directory
    # require presence of the state file inside the archived directory
    pat = os.path.join(ar_dir, f"*.{jobid}")
    for d in glob.glob(pat):
        if os.path.exists(os.path.join(d, "state")):
            return True
    return False


def state_has_job(st_dir, jobid):
    # real naming: <unixtime>.<jobid> directory
    pat = os.path.join(st_dir, f"*.{jobid}")
    for d in glob.glob(pat):
        if os.path.exists(os.path.join(d, "state")):
            return True
    return False


def verify_archive(workdir, finished_jobids):
    st_dir, ar_dir, _ = state_paths(workdir)

    bad = 0
    for jid in finished_jobids:
        in_state = state_has_job(st_dir, jid)
        in_arch = archive_has_job(ar_dir, jid)

        if in_state:
            bad += 1
            elog(f"chaos: verify: job <{jid}> finished but still in state/")
        if not in_arch:
            bad += 1
            elog(f"chaos: verify: job <{jid}> finished but missing in .archive/")

    return bad



def verify_archive_grace(workdir, finished_jobids, grace=ARCHIVE_GRACE, poll=ARCHIVE_POLL):
    st_dir, ar_dir, _ = state_paths(workdir)

    remaining = set(int(x) for x in finished_jobids)
    deadline = time.monotonic() + float(grace)

    while remaining and time.monotonic() < deadline:
        done_now = []
        for jid in remaining:
            in_state = state_has_job(st_dir, jid)
            in_arch = archive_has_job(ar_dir, jid)
            if (not in_state) and in_arch:
                done_now.append(jid)
        for jid in done_now:
            remaining.discard(jid)

        if remaining:
            time.sleep(float(poll))

    bad = 0
    for jid in sorted(remaining):
        in_state = state_has_job(st_dir, jid)
        in_arch = archive_has_job(ar_dir, jid)
        if in_state:
            bad += 1
            elog(f"chaos: verify: job <{jid}> finished but still in state/ after {int(grace)}s")
        if not in_arch:
            bad += 1
            elog(f"chaos: verify: job <{jid}> finished but missing in .archive/ after {int(grace)}s")

    return bad



def main():
    ap = argparse.ArgumentParser(
        prog="chaos",
        description="Chaos test: submit jobs and kill daemons.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    ap.add_argument("--hosts-file", required=True)
    ap.add_argument("--seconds", type=int, default=120)
    ap.add_argument("--queue", default="system")
    ap.add_argument("--submit-every", type=int, default=2)
    ap.add_argument("--kill-every", type=int, default=30)
    ap.add_argument("--kinds", default="lim,mbd,sbd")

    ap.add_argument("--workdir", required=True)

    args = ap.parse_args()

    hosts = read_hosts_file(args.hosts_file)
    kinds = [k.strip() for k in args.kinds.split(",") if k.strip()]

    job_cmds = [
        "sleep 1",
        "sleep 2",
        "sleep 10",
        "sleep 20",
        "false",
        "true",
    ]

    submits_ok = 0
    submits_fail = 0
    kills_ok = 0
    kills_skip = 0

    jobids = []

    t0 = time.monotonic()
    t_end = t0 + args.seconds

    next_submit = t0
    next_kill = t0 + args.kill_every

    while time.monotonic() < t_end:

        now = time.monotonic()

        if now >= next_submit:
            cmd_str = random.choice(job_cmds)
            jid = submit_one(args.queue, cmd_str)

            if jid is not None:
                submits_ok += 1
                jobids.append(jid)
                log(f"chaos: submit job <{jid}> cmd={cmd_str}")
            else:
                submits_fail += 1
                log(f"chaos: submit failed cmd={cmd_str}")

            next_submit += args.submit_every

        if args.kill_every > 0 and now >= next_kill:

            victim_kind = random.choice(kinds)
            if hosts:
                victim_host = random.choice(hosts)
            else:
                victim_host = socket.gethostname()

            if not is_up(victim_host, victim_kind):
                kills_skip += 1
                log(f"chaos: skip kill {victim_kind} host={victim_host} (down)")
            else:
                if kill_one(victim_host, victim_kind):
                    kills_ok += 1
                    log(f"chaos: kill {victim_kind} host={victim_host}")
                else:
                    kills_skip += 1
                    log(f"chaos: skip kill {victim_kind} host={victim_host} (fail)")

            next_kill += args.kill_every

        time.sleep(0.05)

    # --- end / summary + verify ---
    finished = []
    bhist_ok = 0
    bhist_err = 0
    bhist_timeout = 0
    status_counts = {}

    verify_bad = 0
    if jobids:
        for jid in jobids:
            st, out, err = bhist_status(jid, BHIST_TIMEOUT)
            status_counts[st] = status_counts.get(st, 0) + 1

            if st == "TIMEOUT":
                bhist_timeout += 1
            elif st == "ERROR":
                bhist_err += 1
            else:
                bhist_ok += 1

            if is_finished_status(st):
                finished.append(jid)

    if True:
        check_workdir_layout(args.workdir)
        verify_bad += verify_archive_grace(args.workdir, finished)

    log(
        f"chaos: duration={args.seconds}s "
        f"submit_ok={submits_ok} submit_fail={submits_fail} "
        f"killed={kills_ok} skipped={kills_skip} "
        f"jobs={len(jobids)} finished={len(finished)} "
        f"bhist_ok={bhist_ok} bhist_err={bhist_err} bhist_timeout={bhist_timeout} "
        f"verify_bad={verify_bad}"
    )

    if status_counts:
        parts = []
        for k in sorted(status_counts.keys()):
            parts.append(f"{k}={status_counts[k]}")
        log("chaos: bhist_status: " + " ".join(parts))

    if verify_bad > 0:
        sys.exit(1)

    sys.exit(0)


if __name__ == "__main__":
    main()
