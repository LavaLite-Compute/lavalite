#!/usr/bin/env python3
#
# pchaos - pending job replay chaos test.
#
# Usage: pchaos [options] /path/to/mbd
#
# Submits PEND-only jobs (sbd closed), then repeatedly kills/restarts
# mbd verifying job state survives each restart. Optionally bkills a
# few jobs per cycle and verifies they disappear.
#
# Copyright (C) LavaLite Contributors - GPL v2
#

import argparse
import os
import re
import random
import subprocess
import sys
import time


def ts():
    return time.strftime("%H:%M:%S")


def log(msg):
    print(f"{ts()} {msg}", flush=True)


def err(msg):
    print(f"{ts()} ERROR: {msg}", file=sys.stderr, flush=True)


def run(cmd, timeout=5):
    try:
        return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                              text=True, timeout=timeout, check=False)
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(cmd, 124, "", "timeout")


def bsub_one(queue):
    cmd = ["bsub", "-o", "/dev/null", "-e", "/dev/null",
           "-q", queue, "sleep", "9999"]
    cp = run(cmd)
    if cp.returncode != 0:
        err(f"bsub failed: {cp.stderr.strip()}")
        return None
    m = re.search(r"Job\s+<(\d+)>", cp.stdout)
    if not m:
        err(f"bsub: can't parse job id from: {cp.stdout.strip()}")
        return None
    return int(m.group(1))


def snapshot(jobids):
    cp = run(["bjobs", "-a"], timeout=8)
    if cp.returncode == 124:
        err("bjobs timed out")
        return None
    result = {}
    for line in cp.stdout.splitlines():
        parts = line.split()
        if len(parts) < 3:
            continue
        try:
            jid = int(parts[0])
        except ValueError:
            continue
        if jid in jobids:
            result[jid] = parts[2].upper()
    return result


def mbd_kill():
    run(["pkill", "-KILL", "-x", "mbd"])
    for _ in range(20):
        time.sleep(0.1)
        if run(["pgrep", "-x", "mbd"]).returncode != 0:
            return True
    err("mbd did not die")
    return False


def mbd_start(mbd_path, conf_dir):
    subprocess.Popen([mbd_path, f"--confdir={conf_dir}"])
    for _ in range(50):
        time.sleep(0.2)
        if run(["pgrep", "-x", "mbd"]).returncode == 0:
            return True
    err("mbd did not come up")
    return False


def bkill(jid):
    cp = run(["bkill", str(jid)])
    if cp.returncode != 0:
        err(f"bkill {jid}: {cp.stderr.strip()}")
        return False
    return True


def main():
    ap = argparse.ArgumentParser(
        prog="pchaos",
        description="PEND job replay chaos: submit, kill mbd, restart, verify.")
    ap.add_argument("mbd", help="path to mbd binary")
    ap.add_argument("--queue",  default="system")
    ap.add_argument("--jobs",   type=int, default=20)
    ap.add_argument("--cycles", type=int, default=5)
    ap.add_argument("--bkill",  type=int, default=3,
                    help="jobs to bkill per cycle (0=none)")
    args = ap.parse_args()

    conf_dir = os.environ.get("LL_CONF_DIR")
    if not conf_dir:
        err("LL_CONF_DIR not set")
        sys.exit(1)

    if not os.path.isfile(args.mbd):
        err(f"mbd not found: {args.mbd}")
        sys.exit(1)

    # --- submit initial batch ---
    log(f"submitting {args.jobs} jobs to queue={args.queue}")
    jobids = set()
    for _ in range(args.jobs):
        jid = bsub_one(args.queue)
        if jid is not None:
            jobids.add(jid)

    if not jobids:
        err("no jobs submitted")
        sys.exit(1)
    log(f"{len(jobids)} jobs pending")

    bad = 0

    for cycle in range(1, args.cycles + 1):
        log(f"--- cycle {cycle}/{args.cycles} ---")

        before = snapshot(jobids)
        if before is None:
            bad += 1
            break
        log(f"before: {len(before)} jobs, statuses: "
            f"{sorted(set(before.values()))}")

        # kill and restart
        if not mbd_kill():
            bad += 1
            break
        if not mbd_start(args.mbd, conf_dir):
            bad += 1
            break
        time.sleep(0.5)

        after = snapshot(jobids)
        if after is None:
            bad += 1
            break

        # verify state survived restart
        for jid, st in before.items():
            st_after = after.get(jid)
            if st_after is None:
                err(f"job <{jid}> missing after restart (was {st})")
                bad += 1
            elif st_after != st:
                err(f"job <{jid}> status {st} -> {st_after} after restart")
                bad += 1

        survived = len(before) - bad
        log(f"restart verify: {survived}/{len(before)} OK")

        # bkill a random subset
        if args.bkill > 0:
            pend = [jid for jid, st in after.items() if st == "PEND"]
            to_kill = random.sample(pend, min(args.bkill, len(pend)))
            for jid in to_kill:
                bkill(jid)
                jobids.discard(jid)
            log(f"bkilled {len(to_kill)} jobs")
            time.sleep(0.5)

            # verify they're gone
            check = snapshot(set(to_kill))
            if check is None:
                bad += 1
            else:
                for jid in to_kill:
                    st = check.get(jid)
                    if st not in (None, "EXIT", "DONE"):
                        err(f"job <{jid}> still alive as {st} after bkill")
                        bad += 1

    log(f"done: cycles={args.cycles} bad={bad}")
    sys.exit(0 if bad == 0 else 1)


if __name__ == "__main__":
    main()
