#!/usr/bin/env python3
#
# Chaos - KISS version + verify
#
# Verify: bhist is the source of truth. Every submitted job must be
# DONE or EXIT when the run ends. The sbd .archive directory is an
# internal sbd implementation detail and is not checked here.
#
#  Copyright (C) LavaLite Contributors
#  GPL v2
#

import argparse
import random
import re
import shlex
import socket
import subprocess
import sys
import time


DEFAULT_TIMEOUT = 5.0
BHIST_TIMEOUT   = 60.0

PROC_NAMES = {
    "lim": "lim",
    "mbd": "mbd",
    "sbd": "sbd",
}


def ts():
    return time.strftime("%Y-%m-%d %H:%M:%S")


def log(msg):
    sys.stdout.write(f"{ts()} {msg}\n")
    sys.stdout.flush()


def elog(msg):
    sys.stderr.write(f"{ts()} {msg}\n")
    sys.stderr.flush()


def run(cmd, timeout=DEFAULT_TIMEOUT):
    try:
        return subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
            check=False,
        )
    except subprocess.TimeoutExpired as e:
        out = e.stdout if e.stdout is not None else ""
        err = e.stderr if e.stderr is not None else ""
        return subprocess.CompletedProcess(cmd, 124, out, err)


def extract_jobid(txt):
    m = re.search(r"Job\s+<(\d+)>", txt)
    if not m:
        return None
    try:
        return int(m.group(1))
    except Exception:
        return None


def submit_one(queue, cmd_str):
    cmd = ["bsub", "-o", "/dev/null", "-e", "/dev/null"]
    if queue:
        cmd += ["-q", queue]

    try:
        cmd += shlex.split(cmd_str)
    except ValueError as e:
        elog(f"chaos: bad command string: {cmd_str!r}: {e}")
        return None

    cp = run(cmd)

    if cp.returncode == 124:
        if cp.stderr:
            for line in cp.stderr.splitlines():
                elog(line)
        else:
            elog(f"chaos: timeout: {' '.join(cmd)}")
        return None

    if cp.returncode != 0:
        if cp.stderr:
            for line in cp.stderr.splitlines():
                elog(line)
        else:
            elog(f"chaos: command failed rc={cp.returncode}: {' '.join(cmd)}")
        return None

    return extract_jobid(cp.stdout)


def read_hosts_file(path):
    hosts = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            hosts.append(line)
    return hosts


def is_up(host, kind):
    proc = PROC_NAMES.get(kind)
    if not proc:
        return False

    if host == socket.gethostname():
        cp = run(["pgrep", "-x", proc])
        return cp.returncode == 0

    cp = run(["ssh", host, "pgrep", "-x", proc])
    return cp.returncode == 0


def kill_one(host, kind):
    proc = PROC_NAMES.get(kind)
    if not proc:
        return False

    if host == socket.gethostname():
        cp = run(["pkill", "-KILL", "-x", proc])
        return cp.returncode == 0

    cp = run(["ssh", host, "pkill", "-KILL", "-x", proc])
    return cp.returncode == 0


def bhist_all(timeout):
    """Call bhist once with no args, return dict of jobid -> status.
    One call covers all jobs regardless of history size."""
    cp = run(["bhist"], timeout=timeout)

    if cp.returncode == 124:
        elog("chaos: verify: bhist timed out")
        return None

    if cp.returncode != 0:
        elog(f"chaos: verify: bhist failed rc={cp.returncode}")
        if cp.stderr:
            for line in cp.stderr.splitlines():
                elog(line)
        return None

    # Each job appears on one summary line:
    # Job <308>, User <david>, ... Status <DONE> ...
    result = {}
    for line in cp.stdout.splitlines():
        m = re.search(r"Job\s+<(\d+)>.*Status\s+<([^>]+)>", line)
        if not m:
            continue
        try:
            jid = int(m.group(1))
        except ValueError:
            continue
        result[jid] = m.group(2).strip().upper()

    return result


def is_finished_status(st):
    # DONE = success, EXIT = non-zero exit. Both are finished.
    return st in ("DONE", "EXIT")


def main():
    ap = argparse.ArgumentParser(
        prog="chaos",
        description="Chaos test: submit jobs and kill daemons.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    ap.add_argument("--hosts-file", required=True)
    ap.add_argument("--seconds",      type=int, default=120)
    ap.add_argument("--queue",        default="system")
    ap.add_argument("--submit-every", type=int, default=2)
    ap.add_argument("--kill-every",   type=int, default=30)
    ap.add_argument("--kinds",        default="lim,mbd,sbd")

    args = ap.parse_args()

    hosts = read_hosts_file(args.hosts_file)
    kinds = [k.strip() for k in args.kinds.split(",") if k.strip()]

    job_cmds = [
        "sleep 1",
        "sleep 2",
        "sleep 10",
        "sleep 20",
        "false",
        "true",
    ]

    submits_ok   = 0
    submits_fail = 0
    kills_ok     = 0
    kills_skip   = 0

    jobids = []

    t0    = time.monotonic()
    t_end = t0 + args.seconds

    next_submit = t0
    next_kill   = t0 + args.kill_every

    while time.monotonic() < t_end:

        now = time.monotonic()

        if now >= next_submit:
            cmd_str = random.choice(job_cmds)
            jid = submit_one(args.queue, cmd_str)

            if jid is not None:
                submits_ok += 1
                jobids.append(jid)
                log(f"chaos: submit job <{jid}> cmd={cmd_str}")
            else:
                submits_fail += 1
                log(f"chaos: submit failed cmd={cmd_str}")

            next_submit += args.submit_every

        if args.kill_every > 0 and now >= next_kill:

            victim_kind = random.choice(kinds)
            if hosts:
                victim_host = random.choice(hosts)
            else:
                victim_host = socket.gethostname()

            if not is_up(victim_host, victim_kind):
                kills_skip += 1
                log(f"chaos: skip kill {victim_kind} host={victim_host} (down)")
            else:
                if kill_one(victim_host, victim_kind):
                    kills_ok += 1
                    log(f"chaos: kill {victim_kind} host={victim_host}")
                else:
                    kills_skip += 1
                    log(f"chaos: skip kill {victim_kind} host={victim_host} (fail)")

            next_kill += args.kill_every

        time.sleep(0.05)

    # --- verify: bhist is the source of truth ---
    #
    # One bhist call returns all jobs. Every job we submitted must be
    # DONE or EXIT. UNKNOWN means it was not in bhist output -- that
    # is a bug (mbd lost the job).

    finished     = 0
    not_finished = 0
    status_counts = {}

    log("chaos: waiting for all jobs to finish...")
    while True:
        all_status = bhist_all(BHIST_TIMEOUT)
        if all_status is None:
            break
        still_running = [jid for jid in jobids
                         if all_status.get(jid, "UNKNOWN") not in ("DONE", "EXIT")]
        if not still_running:
            break
        log(f"chaos: still running: {len(still_running)} jobs, waiting...")
        time.sleep(5)

    log(f"chaos: verify: checking {len(jobids)} jobs...")
    for jid in jobids:
        if all_status is None:
            st = "ERROR"
        else:
            st = all_status.get(jid, "UNKNOWN")

        status_counts[st] = status_counts.get(st, 0) + 1

        if is_finished_status(st):
            finished += 1
        else:
            not_finished += 1
            elog(f"chaos: verify: job <{jid}> not finished: status={st}")

    verify_bad = not_finished
    if all_status is None:
        verify_bad = len(jobids)

    log(
        f"chaos: duration={args.seconds}s "
        f"submit_ok={submits_ok} submit_fail={submits_fail} "
        f"killed={kills_ok} skipped={kills_skip} "
        f"jobs={len(jobids)} finished={finished} not_finished={not_finished} "
        f"verify_bad={verify_bad}"
    )

    if status_counts:
        parts = [f"{k}={status_counts[k]}" for k in sorted(status_counts.keys())]
        log("chaos: bhist_status: " + " ".join(parts))

    if verify_bad > 0:
        sys.exit(1)

    sys.exit(0)


if __name__ == "__main__":
    main()
