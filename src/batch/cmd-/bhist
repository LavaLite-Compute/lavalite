#!/usr/bin/env python3

import argparse
import shlex
import datetime
import os
import sys
import glob

envdir = os.environ.get("LSF_ENVDIR", "").strip()
if not envdir:
    raise SystemExit("bhist: $LSF_ENVDIR is not set")

prefix = os.path.dirname(envdir.rstrip("/"))
pylib = os.path.join(prefix, "share", "lavalite", "pylib")

if not os.path.isfile(os.path.join(pylib, "llpaths.py")):
    raise SystemExit(f"bhist: missing {pylib}/llpaths.py (install broken)")

sys.path.insert(0, pylib)

from llpaths import lsb_events, LLConfigError

JOB_STAT_PEND    = 0x01
JOB_STAT_RUN     = 0x04
JOB_STAT_EXIT    = 0x20
JOB_STAT_DONE    = 0x40
JOB_STAT_UNKNOWN = 0x10000


def fmt_time(t):
    dt = datetime.datetime.fromtimestamp(int(t))
    return dt.strftime("%a %b %d %H:%M:%S")


def parse(line):
    return shlex.split(line)


def new_job_struct(jobid):
    return {
        "jobId": jobid,
        "user": "?",
        "queue": "?",
        "project": "default",
        "submit_host": "?",
        "cwd": "?",
        "command": "?",
        "exec_host": "?",
        "status": "UNKNOWN",
        "start_time": None,
        "timeline": [],

        # Parsing flags (used to stop scanning history files once a complete
        # history is found for a specific job id).
        "saw_new": False,
        "saw_terminal": False,
    }


def print_job(job):

    print("Job <%d>, User <%s>, Project <%s>, Status <%s>, Queue <%s>"
          % (job["jobId"], job["user"],
             job["project"], job["status"],
             job["queue"]))

    print("Submitted from host <%s>, CWD <%s>, Command <%s>"
          % (job["submit_host"],
             job["cwd"],
             job["command"]))

    print("")

    for l in job["timeline"]:
        print(l)

    print("")


def extract_project_command(tok):

    arch_i = -1
    for i in range(len(tok)):
        if "_linux" in tok[i]:
            arch_i = i
            break

    if arch_i >= 5:
        return tok[arch_i - 2], tok[arch_i - 5]

    return "default", "?"


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("jobid", nargs="?", type=int)
    ap.add_argument("--events", default=None,
                    help="Path to lsb.events (default: derived from $LSF_ENVDIR/lsf.conf)")
    args = ap.parse_args()

    if args.events is None:
        try:
            events_path = lsb_events()
        except LLConfigError as e:
            raise SystemExit(f"bhist: {e}")
    else:
        events_path = args.events

    wanted_job = args.jobid

    numbered = sorted(
        [f for f in glob.glob(events_path + ".*")
         if f.rsplit(".", 1)[-1].isdigit()],
        key=lambda f: int(f.rsplit(".", 1)[-1])
    )
    event_files = [events_path] + numbered

    jobs = {}
    order = []

    found_complete = False

    for efile in event_files:
        if not os.path.exists(efile):
            continue


        # If we already reconstructed a complete history for a specific job,
        # do not scan older rotated files (they will contain prior recycled
        # instances of the same job id).
        if wanted_job and found_complete:
            break
        with open(efile, "r", errors="replace") as f:
            for line in f:

                line = line.strip()
                if not line.startswith('"'):
                    continue

                tok = parse(line)
                ev = tok[0]

                if ev not in (
                    "JOB_NEW",
                    "JOB_START",
                    "JOB_EXECUTE",
                    "JOB_SIGNAL",
                    "JOB_STATUS"
                ):
                    continue

                jobid = int(tok[3])

                if wanted_job and jobid != wanted_job:
                    continue

                if jobid not in jobs:
                    jobs[jobid] = new_job_struct(jobid)
                    order.append(jobid)

                job = jobs[jobid]

                # ---------- JOB_NEW ----------
                if ev == "JOB_NEW":

                    # For a specific job id, keep only the first (most recent)
                    # JOB_NEW we encounter while scanning newest-to-oldest.
                    # Any additional JOB_NEW events for the same job id belong
                    # to older recycled runs and must be ignored.
                    if wanted_job and job["saw_new"]:
                        continue

                    ts = tok[2]

                    job["user"] = tok[13]
                    job["queue"] = tok[28]
                    job["submit_host"] = tok[30]
                    job["cwd"] = tok[31]

                    proj, cmd = extract_project_command(tok)
                    job["project"] = proj
                    job["command"] = cmd

                    job["status"] = "PEND"
                    job["saw_new"] = True

                    job["timeline"].append(
                        "%s: Submitted from host <%s>, to Queue <%s>"
                        % (fmt_time(ts),
                           job["submit_host"],
                           job["queue"])
                    )

                    job["timeline"].append(
                        "%s: Job was queued." % fmt_time(ts)
                    )

                # ---------- JOB_START ----------
                elif ev == "JOB_START":

                    ts = tok[2]
                    host = tok[9]

                    job["exec_host"] = host
                    job["start_time"] = int(ts)
                    job["status"] = "RUN"

                    job["timeline"].append(
                        "%s: Dispatched to <%s>"
                        % (fmt_time(ts), host)
                    )

                # ---------- JOB_EXECUTE ----------
                elif ev == "JOB_EXECUTE":

                    ts = tok[2]

                    job["timeline"].append(
                        "%s: Started on <%s>"
                        % (fmt_time(ts), job["exec_host"])
                    )

                # ---------- JOB_SIGNAL ----------
                elif ev == "JOB_SIGNAL":

                    ts = tok[2]
                    sig = tok[6]
                    user = tok[8]

                    job["timeline"].append(
                        "%s: Job was signaled (%s) by <%s>"
                        % (fmt_time(ts), sig, user)
                    )

                # ---------- JOB_STATUS ----------
                elif ev == "JOB_STATUS":

                    ts = tok[2]
                    jstat = int(tok[4])

                    cpu = int(float(tok[7]))
                    end_time = int(tok[8])

                    runtime = 0
                    if job["start_time"] is not None:
                        runtime = end_time - job["start_time"]

                    if jstat & JOB_STAT_DONE:
                        job["status"] = "DONE"
                        job["saw_terminal"] = True

                        job["timeline"].append(
                            "%s: Done successfully. The CPU time used is %d seconds."
                            % (fmt_time(ts), cpu)
                        )

                        job["timeline"].append(
                            "%s: The run time was %d seconds."
                            % (fmt_time(ts), runtime)
                        )
                    elif jstat & JOB_STAT_EXIT:
                        job["status"] = "EXIT"
                        job["saw_terminal"] = True

                        job["timeline"].append(
                            "%s: Exited. The CPU time used is %d seconds."
                            % (fmt_time(ts), cpu)
                        )

                        job["timeline"].append(
                            "%s: The run time was %d seconds."
                            % (fmt_time(ts), runtime)
                        )
                    elif jstat & JOB_STAT_UNKNOWN:
                        job["status"] = "UNKNOWN"

                if wanted_job:
                    if job["saw_new"] and job["saw_terminal"]:
                        found_complete = True
                        break

            if wanted_job and found_complete:
                break

    first = True
    for jid in order:

        if not first:
            print("------------------------------------------------")

        print_job(jobs[jid])
        first = False


if __name__ == "__main__":
    main()
